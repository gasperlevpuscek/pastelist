<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="@color/backgroundWhite"
    android:background="@color/backgroundWhite">

    <EditText
        android:id="@+id/atTaskName"
        android:layout_width="379dp"
        android:layout_height="48dp"
        android:autofillHints="Task name"
        android:background="@null"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:hint="@string/task_name"
        android:textColorHint="@color/hintGray"
        android:textColor="@color/textGray"
        android:inputType="text" />

    <EditText
        android:background="@null"
        android:id="@+id/atTaskDescription"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="@string/task_description"
        android:textColorHint="@color/hintGray"
        android:inputType="textMultiLine"
        android:layout_marginTop="8dp"
        android:textColor="@color/textGray"
        android:autofillHints="Description"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <!-- Add button (far right) -->
        <ImageButton
            android:id="@+id/atTaskAdd"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="8dp"
            android:background="@color/pastelistGreen"
            android:contentDescription="@string/add_task"
            android:src="@android:drawable/ic_menu_send"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/white" />

        <!-- Reminder button (middle) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/atTaskReminder"
            android:layout_width="0dp"
            android:layout_height="49dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="Reminder"
            android:textAllCaps="false"
            android:textColor="@color/textGray"
            android:backgroundTint="@color/white"
            app:cornerRadius="12dp"
            app:layout_constraintStart_toEndOf="@id/atTaskOpenDatePicker"
            app:layout_constraintEnd_toStartOf="@id/atTaskAdd"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Date button (left) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/atTaskOpenDatePicker"
            android:layout_width="0dp"
            android:layout_height="49dp"
            android:layout_marginStart="8dp"
            android:text="@string/date"
            android:textAllCaps="false"
            android:textColor="@color/textGray"
            android:backgroundTint="@color/white"
            app:cornerRadius="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/atTaskReminder"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>